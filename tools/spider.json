{
    "category": "spider",
    "description": "Web scraping tools for content and e-commerce research",
    "implementation_module": "implementations.spider_impl",
    "tools": [
        {
            "name": "scrape_youtube_trending",
            "endpoint": "/spider/scrape_youtube_trending",
            "description": "جمع trending videos من YouTube",
            "function": "scrape_youtube_trending",
            "params": {
                "category": {
                    "type": "string",
                    "required": false,
                    "default": "all"
                },
                "count": {
                    "type": "integer",
                    "required": false,
                    "default": 20
                },
                "country": {
                    "type": "string",
                    "required": false,
                    "default": "US"
                }
            }
        },
