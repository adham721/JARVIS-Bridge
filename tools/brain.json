            "params": {
                "title": {
                    "type": "string",
                    "required": true
                }
            }
        },
        {
            "name": "analyze_hook",
            "endpoint": "/brain/analyze_hook",
            "description": "تحليل جودة البداية/الـ Hook",
            "function": "analyze_hook",
            "params": {
                "text": {
                    "type": "string",
                    "required": true
