        {
            "name": "analyze_tone",
            "endpoint": "/brain/analyze_tone",
            "description": "Analyze emotional tone",
            "function": "analyze_tone",
            "params": {
                "text": {
                    "type": "string",
                    "required": true
                }
            }
        },
        {
            "name": "difficulty_score",
            "endpoint": "/brain/difficulty_score",
            "description": "Rate text difficulty",
            "function": "difficulty_score",
            "params": {
                "text": {
                    "type": "string",
                    "required": true
                }
            }
        },
        {
            "name": "auto_summarize",
            "endpoint": "/brain/auto_summarize",
            "description": "Auto summarize text",
            "function": "auto_summarize",
            "params": {
                "text": {
                    "type": "string",
                    "required": true
