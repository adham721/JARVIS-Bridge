# Database
DB_PASSWORD=your_secure_password_here

# N8N
N8N_PASSWORD=change_me

# AI APIs
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-1.5-flash
YOUTUBE_API_KEY=
ETSY_API_KEY=
AMAZON_SP_API_CLIENT_ID=
AMAZON_SP_API_CLIENT_SECRET=
# Optional: YouTube Deep Pack (thumbnail/hook/hashtags/comments terms)
JARVIS_YOUTUBE_FORCE_DETAILS=1
JARVIS_YOUTUBE_DETAILS_LIMIT=6
JARVIS_YOUTUBE_DETAILS_GET_COMMENTS=1
JARVIS_YOUTUBE_MAX_COMMENTS=12

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
# Optional: lock Focus Bot to one chat (defaults to TELEGRAM_CHAT_ID)
JARVIS_TELEGRAM_FOCUS_CHAT_ID=
# Optional: platform health alert events (sent only on regression/spike vs previous run)
JARVIS_TELEGRAM_PLATFORM_ALERTS_ENABLED=1
JARVIS_TELEGRAM_BLOCK_ALERT_THRESHOLD=0.40
JARVIS_TELEGRAM_BLOCK_ALERT_DELTA=0.15

# Gateway
JARVIS_API_KEY=change_me
# Backward-compat (older scripts may read API_KEY)
API_KEY=change_me

# Optional (Signals via SearXNG)
SEARXNG_URL=http://localhost:8888

# Optional (Signals cache dir)
# Default is: <repo>/cache/signals
JARVIS_CACHE_DIR=

# Optional (Manual Intelligence Bridge inbox)
# Default is: <repo>/data/intel_inbox
JARVIS_INTEL_DIR=
# Optional (Manual Intelligence Bridge outbox)
# Default is: sibling of inbox: <repo>/data/intel_outbox
JARVIS_INTEL_OUTBOX_DIR=
# Max JSON packets imported per run (default: 20)
JARVIS_INTEL_MAX_FILES=20
# Max Intel Requests generated per run (default: 2)
JARVIS_INTEL_REQUESTS_MAX=2

# Optional (MongoDB Intel Bridge)
# Enable queue-based bridge (recommended replacement for Drive Actions)
JARVIS_MONGO_BRIDGE_ENABLED=0
JARVIS_MONGO_URI=
JARVIS_MONGO_DB=jarvis_intel
JARVIS_MONGO_JOBS_COLLECTION=intel_jobs
JARVIS_MONGO_INTEL_COLLECTION=intel_packets
JARVIS_MONGO_CONNECT_TIMEOUT_MS=6000
JARVIS_BRIDGE_JOB_LOCK_SECONDS=900
JARVIS_MONGO_RETRY_ATTEMPTS=3
JARVIS_MONGO_RETRY_BACKOFF_SECONDS=1.2
JARVIS_MONGO_INTEL_MAX_FILES=20
JARVIS_BRIDGE_API_KEY=change_me
# Optional: external bridge URL for wake check (e.g. Render/Azure)
JARVIS_BRIDGE_SERVER_URL=

# Optional (Local LLM via Ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Optional (OpenClaw mission bridge)
JARVIS_OPENCLAW_ENABLED=1
JARVIS_OPENCLAW_MAX_MISSIONS=3
JARVIS_OPENCLAW_REAUTH_MAX=2
JARVIS_OPENCLAW_HARDENING_MAX=2
JARVIS_OPENCLAW_HARDENING_MIN_BLOCK_RATE=0.5
JARVIS_OPENCLAW_REAUTH_COOLDOWN_HOURS=12
JARVIS_OPENCLAW_COVERAGE_LOOKBACK_HOURS=24
JARVIS_OPENCLAW_OUTBOX_DIR=
JARVIS_OPENCLAW_INBOX_DIR=
JARVIS_OPENCLAW_WEBHOOK_URL=
